{
  "name": "xotp",
  "description": "One-Time Password (HOTP/TOTP) library for Node.js, Deno and Bun, with support for Google Authenticator.",
  "author": "Farshid Beheshti",
  "version": "1.0.16",
  "type": "commonjs",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "prebuild": "npm run clean",
    "build": "tsc && node scripts/build-esm-entry.mjs",
    "prepare": "npm run build",
    "clean": "rimraf ./dist",
    "test:coverage": "rimraf ./coverage & jest --coverage",
    "test": "jest",
    "test:smoke": "node tests/smoke/cjs.cjs && node tests/smoke/esm.mjs",
    "test:smoke:consumer:cjs": "node scripts/test-smoke-consumer.mjs cjs",
    "test:smoke:consumer:esm": "node scripts/test-smoke-consumer.mjs esm",
    "test:smoke:consumer": "npm run test:smoke:consumer:cjs && npm run test:smoke:consumer:esm"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/farshidbeheshti/xotp.git"
  },
  "bugs": "https://github.com/farshidbeheshti/xotp/issues",
  "homepage": "https://xotp.dev",
  "license": "MIT",
  "keywords": [
    "otp",
    "totp",
    "hotp",
    "two-factor authentication",
    "otp generator",
    "2fa",
    "one-time password",
    "google-authenticator",
    "authenticator",
    "multi-factor authentication",
    "two-step authentication",
    "time-based one-time password"
  ],
  "devDependencies": {
    "@types/jest": "^29.5.13",
    "@types/node": "^22.7.6",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}